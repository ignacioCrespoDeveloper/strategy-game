# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Your Supabase project URL (same value as SUPABASE_URL in js/core/config.js)
SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key — used only to verify user JWTs (auth.getUser). Same as in config.js.
SUPABASE_ANON_KEY=your_anon_key_here

# Service role secret — bypasses RLS so the server can read/write any player's data.
# Found in: Supabase Dashboard → Settings → API → service_role
# Keep this server-side only. If exposed, rotate it immediately.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFwcG1wZmNpc3VwZ2ppaGJkY2dwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4Mzg1MjU3MiwiZXhwIjoyMDk5NDI4NTcyfQ.6V0UqT9ECrsYJwNN-ysMyh0bqaxfyWaIQ0IrOMu4DMkre

# HTTP port (optional)
PORT=3000
